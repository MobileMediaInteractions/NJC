{
  "expo": {
    "name": "The New Jersey Courier",
    "slug": "new-jersey-courier",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/courier-icon.png",
    "scheme": "njcourier",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/images/courier-icon.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.mobilemediainteractions.thenews",
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["njcourier-employee"]
      }
    },
    "android": {
      "package": "com.mobilemediainteractions.thenews",
      "adaptiveIcon": {
        "backgroundColor": "#173E32",
        "foregroundImage": "./assets/images/courier-android-foreground.png",
        "monochromeImage": "./assets/images/courier-android-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/courier-favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#173E32",
          "image": "./assets/images/courier-icon.png",
          "imageWidth": 76
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#C49545",
          "defaultChannel": "breaking-news"
        }
      ],
      "expo-secure-store",
      "expo-sqlite",
      "expo-video",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow The New Jersey Courier to scan secure sign-in QR codes",
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
