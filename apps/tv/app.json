{
  "expo": {
    "name": "Harborline Local TV",
    "slug": "harborline-local-tv",
    "version": "1.0.0",
    "orientation": "landscape",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.mobilemediainteractions.thenews.tv",
      "supportsTablet": false
    },
    "android": {
      "package": "com.mobilemediainteractions.thenews.tv",
      "versionCode": 1
    },
    "plugins": [
      [
        "@react-native-tvos/config-tv",
        {
          "androidTVRequired": true,
          "androidTVBanner": "../web/public/og.png",
          "removeFlipperOnAndroid": true,
          "tvosDeploymentTarget": "17.0"
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "apiUrl": "https://harborline.example",
      "eas": {
        "projectId": "REPLACE_WITH_TV_EAS_PROJECT_ID"
      }
    }
  }
}
