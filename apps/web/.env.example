# Public configuration
# Leave blank on Vercel to use its automatic *.vercel.app production/preview URL.
# Set only after assigning a canonical custom domain, for example https://njcourier.com.
NEXT_PUBLIC_SITE_URL=
# Leave blank to serve /assets from the web deployment. A future CDN may be set here.
NEXT_PUBLIC_ASSET_ORIGIN=
# Keep false until legal, editorial, and operational launch review is complete.
NEXT_PUBLIC_SEO_INDEXING_ENABLED=false
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# Neon Postgres (install Neon from the Vercel Marketplace)
DATABASE_URL=

# Clerk (install Clerk from the Vercel Marketplace)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Developer API key HMAC pepper (generate 32+ random bytes) and Upstash limits.
# Vercel Marketplace currently provides KV_REST_API_*; legacy Upstash names remain supported.
API_KEY_PEPPER=
DEVICE_PAIRING_PEPPER=
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Public press-kit contact shown inside generated archives.
# The generator uses Upstash above for a durable 3-per-hour requester limit.
PRESS_CONTACT_EMAIL=

# Vercel Blob. Keep published media and privileged exports/attachments in separate stores.
BLOB_READ_WRITE_TOKEN=
PRIVATE_BLOB_READ_WRITE_TOKEN=
CRON_SECRET=

# Optional public runtime metadata and National Weather Service identification.
NEXT_PUBLIC_APP_VERSION=
NWS_USER_AGENT=

# Expo mobile/TV local development. Store builds should use the web project's *.vercel.app URL.
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
EXPO_PUBLIC_TV_API_URL=http://localhost:3000
EXPO_ACCESS_TOKEN=

# Dedicated employee app. Use the Vercel *.vercel.app host until a custom domain exists.
EXPO_PUBLIC_EMPLOYEE_API_URL=http://localhost:3000
EXPO_PUBLIC_EMPLOYEE_LINK_HOST=
EXPO_PUBLIC_EMPLOYEE_EAS_PROJECT_ID=
# Server-controlled compatibility and approved distribution destinations. Do not invent store URLs.
EMPLOYEE_MIN_APP_VERSION=1.0.0
EMPLOYEE_IOS_INSTALL_URL=
EMPLOYEE_ANDROID_INSTALL_URL=
EMPLOYEE_INTERNAL_INSTALL_URL=
# Required only when enabling Universal Links/App Links for a deployed host.
# iOS format: TEAM_ID.com.mobilemediainteractions.thenews.employee
EMPLOYEE_IOS_APP_ID=
EMPLOYEE_ANDROID_PACKAGE=com.mobilemediainteractions.thenews.employee
# Comma-separated release-certificate SHA-256 fingerprints.
EMPLOYEE_ANDROID_SHA256_CERT_FINGERPRINTS=

# Studio export safety cap (bytes in a server function)
BACKUP_MAX_BYTES=100000000

# Feature-platform licensing. Generate an Ed25519 key pair; keep the private key only in Vercel secrets.
PLATFORM_LICENSE_ISSUER=
PLATFORM_LICENSE_AUDIENCE=platform-runtime
PLATFORM_LICENSE_KEY_ID=
PLATFORM_ED25519_PRIVATE_KEY_PEM=
PLATFORM_ED25519_PUBLIC_KEY_PEM=
# JSON array of retired public SigningKeyRecord objects retained to verify unexpired receipts.
PLATFORM_ED25519_PREVIOUS_PUBLIC_KEYS_JSON=
PLATFORM_LICENSE_KEY_PEPPER=
PLATFORM_INSTALLATION_PEPPER=

# Optional integrations
RESEND_API_KEY=
NEWSLETTER_WEBHOOK_URL=
NEXT_PUBLIC_ANALYTICS_ID=
