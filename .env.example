# Public configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Neon Postgres (install Neon from the Vercel Marketplace)
DATABASE_URL=

# Clerk (install Clerk from the Vercel Marketplace)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/studio/sign-in

# Vercel Blob (create a Blob store in Vercel)
BLOB_READ_WRITE_TOKEN=
CRON_SECRET=

# Optional integrations
RESEND_API_KEY=
NEWSLETTER_WEBHOOK_URL=
NEXT_PUBLIC_ANALYTICS_ID=

# Local presentation only. Never enable this in production.
CMS_DEMO_MODE=false
