# Public configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Neon Postgres (install Neon from the Vercel Marketplace)
DATABASE_URL=

# Clerk (install Clerk from the Vercel Marketplace)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Developer API key HMAC pepper (generate 32+ random bytes) and Upstash limits
API_KEY_PEPPER=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Blob (create a Blob store in Vercel)
BLOB_READ_WRITE_TOKEN=
CRON_SECRET=

# Expo mobile app and push delivery
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
EXPO_ACCESS_TOKEN=

# Studio export safety cap (bytes in a server function)
BACKUP_MAX_BYTES=100000000

# Optional integrations
RESEND_API_KEY=
NEWSLETTER_WEBHOOK_URL=
NEXT_PUBLIC_ANALYTICS_ID=

# Local presentation only. Never enable this in production.
CMS_DEMO_MODE=false
