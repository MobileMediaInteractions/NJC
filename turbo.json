{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "API_KEY_PEPPER",
        "BACKUP_MAX_BYTES",
        "BING_SITE_VERIFICATION",
        "BLOB_READ_WRITE_TOKEN",
        "CLERK_SECRET_KEY",
        "CRON_SECRET",
        "DATABASE_URL",
        "DEVICE_PAIRING_PEPPER",
        "EMPLOYEE_ANDROID_PACKAGE",
        "EMPLOYEE_ANDROID_SHA256_CERT_FINGERPRINTS",
        "EMPLOYEE_INTERNAL_INSTALL_URL",
        "EMPLOYEE_IOS_APP_ID",
        "EMPLOYEE_IOS_INSTALL_URL",
        "EMPLOYEE_MIN_APP_VERSION",
        "GOOGLE_SITE_VERIFICATION",
        "KV_REST_API_TOKEN",
        "KV_REST_API_URL",
        "NEWSLETTER_WEBHOOK_URL",
        "NEXT_PUBLIC_ANALYTICS_ID",
        "NEXT_PUBLIC_APP_VERSION",
        "NEXT_PUBLIC_ASSET_ORIGIN",
        "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_CLERK_SIGN_IN_URL",
        "NEXT_PUBLIC_CLERK_SIGN_UP_URL",
        "NEXT_PUBLIC_SEO_INDEXING_ENABLED",
        "NEXT_PUBLIC_SITE_URL",
        "NWS_USER_AGENT",
        "PLATFORM_ED25519_PREVIOUS_PUBLIC_KEYS_JSON",
        "PLATFORM_ED25519_PRIVATE_KEY_PEM",
        "PLATFORM_ED25519_PUBLIC_KEY_PEM",
        "PLATFORM_INSTALLATION_PEPPER",
        "PLATFORM_LICENSE_AUDIENCE",
        "PLATFORM_LICENSE_ISSUER",
        "PLATFORM_LICENSE_KEY_ID",
        "PLATFORM_LICENSE_KEY_PEPPER",
        "PRESS_CONTACT_EMAIL",
        "PRIVATE_BLOB_READ_WRITE_TOKEN",
        "RESEND_API_KEY",
        "UPSTASH_REDIS_REST_TOKEN",
        "UPSTASH_REDIS_REST_URL"
      ],
      "outputs": [".next/**", "dist/**", "build/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^test"]
    }
  }
}
