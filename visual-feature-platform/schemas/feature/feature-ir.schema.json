{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.example.invalid/visual-feature/feature-ir-v1.schema.json",
  "title": "Visual Feature IR v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "name", "version", "minimumRuntime", "supportedPlatforms", "entitlement", "capabilities", "designTokens", "dataModels", "state", "screens", "behaviors", "connectors", "motions", "localizations", "tests", "migrations"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "$ref": "#/$defs/id" },
    "name": { "type": "string", "minLength": 1, "maxLength": 120 },
    "version": { "$ref": "#/$defs/semver" },
    "minimumRuntime": { "$ref": "#/$defs/semver" },
    "supportedPlatforms": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["web", "ios", "android", "tvos", "androidtv", "roku", "desktop"] } },
    "entitlement": { "type": "string", "minLength": 1 },
    "capabilities": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
    "designTokens": { "type": "object" },
    "dataModels": { "type": "array", "items": { "$ref": "#/$defs/dataModel" } },
    "state": { "type": "array", "items": { "$ref": "#/$defs/stateField" } },
    "screens": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/screen" } },
    "behaviors": { "type": "array", "items": { "$ref": "#/$defs/behavior" } },
    "connectors": { "type": "array", "items": { "type": "object", "required": ["id", "name", "kind", "capabilities", "operations"], "properties": { "id": { "$ref": "#/$defs/id" }, "name": { "type": "string" }, "kind": { "enum": ["rest", "graphql", "websocket", "sse", "local-storage", "secure-storage", "host", "media"] }, "credentialReference": { "type": "string", "pattern": "^host:[a-z][a-z0-9.-]+$" }, "capabilities": { "type": "array", "items": { "type": "string" } }, "operations": { "type": "array", "items": { "type": "object" } } }, "additionalProperties": true } },
    "motions": { "type": "array", "items": { "type": "object", "required": ["id", "name", "durationMs", "tracks", "markers"], "properties": { "id": { "$ref": "#/$defs/id" }, "name": { "type": "string" }, "durationMs": { "type": "integer", "minimum": 0, "maximum": 86400000 }, "tracks": { "type": "array" }, "markers": { "type": "array" } }, "additionalProperties": true } },
    "localizations": { "type": "object", "additionalProperties": { "type": "object", "additionalProperties": { "type": "string" } } },
    "tests": { "type": "array", "items": { "type": "object" } },
    "migrations": { "type": "array", "items": { "type": "object" } }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$", "maxLength": 160 },
    "semver": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$" },
    "dataModel": { "type": "object", "required": ["id", "name", "fields"], "properties": { "id": { "$ref": "#/$defs/id" }, "name": { "type": "string" }, "fields": { "type": "array", "items": { "type": "object", "required": ["id", "name", "type"], "properties": { "id": { "$ref": "#/$defs/id" }, "name": { "type": "string" }, "type": { "type": "string" } }, "additionalProperties": true } } }, "additionalProperties": true },
    "stateField": { "type": "object", "required": ["id", "name", "type", "scope"], "properties": { "id": { "$ref": "#/$defs/id" }, "name": { "type": "string" }, "type": { "type": "string" }, "scope": { "enum": ["local", "screen", "feature", "session", "application", "persisted", "secure", "server"] } }, "additionalProperties": true },
    "component": { "type": "object", "required": ["id", "name", "type", "properties", "layout", "accessibility", "bindings", "children"], "properties": { "id": { "$ref": "#/$defs/id" }, "name": { "type": "string" }, "type": { "type": "string" }, "properties": { "type": "object" }, "layout": { "type": "object" }, "accessibility": { "type": "object" }, "bindings": { "type": "array" }, "children": { "type": "array", "items": { "$ref": "#/$defs/component" } } }, "additionalProperties": true },
    "screen": { "type": "object", "required": ["id", "name", "route", "root"], "properties": { "id": { "$ref": "#/$defs/id" }, "name": { "type": "string" }, "route": { "type": "string" }, "root": { "$ref": "#/$defs/component" } }, "additionalProperties": true },
    "behavior": { "type": "object", "required": ["id", "name", "trigger", "nodes", "edges"], "properties": { "id": { "$ref": "#/$defs/id" }, "name": { "type": "string" }, "trigger": { "type": "object", "required": ["componentId", "event"], "properties": { "componentId": { "$ref": "#/$defs/id" }, "event": { "type": "string" } } }, "nodes": { "type": "array", "items": { "type": "object" } }, "edges": { "type": "array", "items": { "type": "object" } } }, "additionalProperties": true }
  }
}
