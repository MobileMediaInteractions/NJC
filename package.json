{
  "name": "new-jersey-courier-platform",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "turbo run dev --filter=@njcourier/web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "check": "turbo run test lint typecheck build",
    "web:start": "pnpm --dir apps/web start",
    "mobile:start": "pnpm --dir apps/mobile start",
    "mobile:check": "pnpm --dir apps/mobile typecheck && pnpm --dir apps/mobile lint",
    "employee:start": "pnpm --dir apps/employee start",
    "employee:check": "pnpm --dir apps/employee test && pnpm --dir apps/employee typecheck && pnpm --dir apps/employee lint",
    "employee:export": "pnpm --dir apps/employee export:ios && pnpm --dir apps/employee export:android",
    "platform:check": "pnpm --dir platform check",
    "platform:demo": "pnpm --dir platform demo",
    "platform:benchmark": "pnpm --dir platform benchmark",
    "platform:conformance": "pnpm --dir platform conformance",
    "playground:start": "pnpm --dir apps/platform-playground dev",
    "playground:check": "pnpm --dir apps/platform-playground typecheck && pnpm --dir apps/platform-playground lint && pnpm --dir apps/platform-playground build",
    "studio:start": "pnpm --dir tools/studio tauri:dev",
    "studio:web": "pnpm --dir tools/studio dev",
    "studio:check": "pnpm --dir tools/studio check",
    "studio:build": "pnpm --dir tools/studio tauri:build:no-bundle",
    "composer:check": "pnpm --dir visual-feature-platform check && pnpm studio:check",
    "composer:demo": "pnpm --dir visual-feature-platform demo",
    "composer:benchmark": "pnpm --dir visual-feature-platform benchmark",
    "composer:playground": "pnpm --dir visual-feature-platform playground",
    "tv:start": "pnpm --dir apps/tv start",
    "tv:check": "pnpm --dir apps/tv typecheck && pnpm --dir apps/tv lint",
    "tv:prebuild:android": "pnpm --dir apps/tv prebuild:android-tv",
    "tv:android": "pnpm --dir apps/tv android-tv",
    "roku:check": "pnpm --dir apps/roku test && pnpm --dir apps/roku typecheck",
    "roku:build": "pnpm --dir apps/roku build",
    "roku:package": "pnpm --dir apps/roku package:production",
    "roku:install": "pnpm --dir apps/roku install:device",
    "db:generate": "pnpm --dir apps/web db:generate",
    "db:migrate": "pnpm --dir apps/web db:migrate",
    "db:push": "pnpm --dir apps/web db:push",
    "db:seed": "pnpm --dir apps/web db:seed",
    "backup:export": "pnpm --dir apps/web backup:export",
    "backup:restore": "pnpm --dir apps/web backup:restore"
  },
  "devDependencies": {
    "turbo": "^2.8.10"
  }
}
