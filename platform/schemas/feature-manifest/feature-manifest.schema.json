{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://platform.invalid/schemas/feature-manifest-v1.json",
  "title": "Platform feature manifest v1",
  "type": "object",
  "required": ["schemaVersion", "id", "displayName", "description", "version", "publisher", "minimumHostRuntime", "maximumTestedHostRuntime", "supportedPlatforms", "entryPoint", "lifecyclePolicy", "killSwitchKey", "requiredHostCapabilities", "optionalHostCapabilities", "licenseEntitlement", "dependencies", "conflicts", "configurationSchema", "commands", "eventsEmitted", "eventsConsumed", "uiSurfaces", "backgroundServices", "permissions", "dataMigrations", "featureFlags", "privacy", "resourceRequirements", "packageChecksum"],
  "$defs": {
    "identifier": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$", "maxLength": 128 },
    "semver": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$" },
    "schema": { "type": "object" }
  },
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "$ref": "#/$defs/identifier" },
    "displayName": { "type": "string", "minLength": 1, "maxLength": 120 },
    "description": { "type": "string", "maxLength": 1000 },
    "version": { "$ref": "#/$defs/semver" },
    "publisher": { "$ref": "#/$defs/identifier" },
    "minimumHostRuntime": { "$ref": "#/$defs/semver" },
    "maximumTestedHostRuntime": { "$ref": "#/$defs/semver" },
    "supportedPlatforms": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["web", "ios", "android", "tvos", "androidtv", "roku", "node"] } },
    "entryPoint": { "type": "string", "minLength": 1, "maxLength": 300 },
    "lifecyclePolicy": { "type": "object", "required": ["start", "background", "failure"], "properties": { "start": { "enum": ["eager", "lazy"] }, "background": { "enum": ["suspend", "continue", "stop"] }, "failure": { "enum": ["isolate", "fail-host"] } }, "additionalProperties": false },
    "killSwitchKey": { "$ref": "#/$defs/identifier" },
    "requiredHostCapabilities": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
    "optionalHostCapabilities": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
    "licenseEntitlement": { "$ref": "#/$defs/identifier" },
    "dependencies": { "type": "array", "items": { "type": "object", "required": ["id", "range", "optional"], "properties": { "id": { "$ref": "#/$defs/identifier" }, "range": { "type": "string" }, "optional": { "type": "boolean" } }, "additionalProperties": false } },
    "conflicts": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/identifier" } },
    "configurationSchema": { "$ref": "#/$defs/schema" },
    "commands": { "type": "array", "items": { "type": "object" } },
    "eventsEmitted": { "type": "array", "items": { "type": "object" } },
    "eventsConsumed": { "type": "array", "items": { "type": "object" } },
    "uiSurfaces": { "type": "array", "items": { "type": "object" } },
    "backgroundServices": { "type": "array", "items": { "$ref": "#/$defs/identifier" } },
    "permissions": { "type": "array", "items": { "type": "string" } },
    "dataMigrations": { "type": "array", "items": { "type": "object" } },
    "featureFlags": { "type": "array", "items": { "$ref": "#/$defs/identifier" } },
    "privacy": { "type": "object", "required": ["dataCategories", "purposes", "retentionDays", "sharesExternally"], "properties": { "dataCategories": { "type": "array", "items": { "$ref": "#/$defs/identifier" } }, "purposes": { "type": "array", "items": { "type": "string" } }, "retentionDays": { "type": "integer", "minimum": 0, "maximum": 36500 }, "sharesExternally": { "type": "boolean" } }, "additionalProperties": false },
    "resourceRequirements": { "type": "object", "required": ["maxMemoryMb", "maxStorageMb", "networkRequired"], "properties": { "maxMemoryMb": { "type": "integer", "minimum": 1, "maximum": 2048 }, "maxStorageMb": { "type": "integer", "minimum": 0, "maximum": 10240 }, "networkRequired": { "type": "boolean" } }, "additionalProperties": false },
    "packageSignature": { "type": "object", "required": ["algorithm", "keyId", "value"], "properties": { "algorithm": { "const": "ed25519" }, "keyId": { "$ref": "#/$defs/identifier" }, "value": { "type": "string", "minLength": 40, "maxLength": 256 } }, "additionalProperties": false },
    "packageChecksum": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  },
  "additionalProperties": false
}
